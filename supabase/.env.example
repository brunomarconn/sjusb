# ─────────────────────────────────────────────────────────────
# Variables de entorno para Supabase Edge Functions
# Configurar en: Supabase Dashboard → Settings → Edge Functions → Secrets
# ─────────────────────────────────────────────────────────────

# Supabase (se inyectan automáticamente — NO hace falta configurarlas a mano)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ── Variables que SÍ hay que configurar manualmente ──────────

# URL de la app frontend (para los back_urls de MercadoPago)
APP_URL=https://mservicios.pages.dev

# Contraseña del panel admin (usada en el header x-admin-secret)
ADMIN_SECRET=cambia-esta-clave-segura

# Proveedor de pagos: "mock" (dev) | "mercadopago" (prod)
PAYMENT_MODE=mock

# Access Token de MercadoPago (solo necesario si PAYMENT_MODE=mercadopago)
# Obtenerlo en: https://www.mercadopago.com.ar/developers/panel
MP_ACCESS_TOKEN=APP_USR-...
